title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
!}

= Status

[+ month : month +] [+ year +]

Resources available: [+ resources +]

SDP position: [? if sdp_toleration : toleration ?][? if sdp_in_government : in government - ?][? if sdp_toleration == 0 and sdp_in_government == 0 and sdp_caretaker == 0 : opposition ?][? if sdp_caretaker : caretaker government ?]
[? if in_weimar_coalition and sdp_in_government: Weimar Coalition ?][? if in_grand_coalition and sdp_in_government: Grand Coalition ?][? if in_popular_front and sdp_in_government: Popular Front ?][? if in_left_front and sdp_in_government: Left Front ?][? if in_sdp_majority and sdp_in_government: SDP majority ?][? if in_minority_government and sdp_in_government: minority government ?][? if in_emergency_government and sdp_in_government: emergency government ?]

[? if sdp_in_government and not in_sdp_majority and not in_left_front : Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

[? if sdp_in_government and (in_left_front or in_popular_front): CPT coalition dissent: [+ cpt_coalition_dissent : coalition_dissent +] ?]

Internal dissent: [+ dissent_percent : dissent +]

